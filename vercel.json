{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://www.franchiseleadspro.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "franchiseleadspro.com"
        }
      ],
      "destination": "https://www.franchiseleadspro.com/$1",
      "permanent": true
    },
    {
      "source": "/locations/us",
      "destination": "/locations/usa",
      "permanent": true
    },
    {
      "source": "/locations/us/(.*)",
      "destination": "/locations/usa/$1",
      "permanent": true
    },
    {
      "source": "/india",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/home-original",
      "destination": "/usa",
      "permanent": true
    },
    {
      "source": "/search",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/sitemaps/:path*", "destination": "/sitemaps/:path*" },
    { "source": "/sitemap-blog.xml", "destination": "https://yquuidpajigvecyonqir.supabase.co/functions/v1/blog-sitemap" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/llms.txt", "destination": "/llms.txt" },
    { "source": "/llms-full.txt", "destination": "/llms-full.txt" },
    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/favicon-:size.png", "destination": "/favicon-:size.png" },
    { "source": "/og-image.png", "destination": "/og-image.png" },
    { "source": "/logo-hq.png", "destination": "/logo-hq.png" },
    { "source": "/apple-touch-icon.png", "destination": "/apple-touch-icon.png" },
    {
      "source": "/((?!api|_next|static|favicon|robots|sitemap|og-image|logo|apple-touch|assets|src|site\\.webmanifest).*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Googlebot|bingbot|Baiduspider|DuckDuckBot|Slurp|facebookexternalhit|Twitterbot|LinkedInBot|rogerbot|Screaming Frog|SemrushBot|AhrefsBot|YandexBot|Applebot|MJ12bot|Bytespider|PetalBot|DataForSeoBot|GPTBot).*"
        }
      ],
      "destination": "/api/render?path=$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/sitemaps/(.*)\\.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/sitemap-blog.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/robots\\.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/favicon(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(locations|services|franchise-leads|buy-franchise-leads|blog|about|contact|digital-marketing|testimonials)(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow, max-snippet:-1, max-image-preview:large" },
        { "key": "Cache-Control", "value": "public, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(india|home-original|search)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
